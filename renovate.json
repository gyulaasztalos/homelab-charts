{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "automergeSchedule": [
    "after 5am every weekday",
    "before 4pm every weekday",
    "every weekend"
  ],
  "timezone": "Europe/Budapest",
  "platformAutomerge": true,
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "description": "Major updates open a PR (email notification), never auto-merged",
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ],
  "helm-values": {
    "managerFilePatterns": ["/values\\.yaml$/"]
  },
  "helmv3": {
    "managerFilePatterns": ["/Chart\\.yaml$/"]
  },
  "kubernetes": {
    "managerFilePatterns": ["/charts/.+/templates/.+\\.ya?ml$/"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update container image tags in values.yaml annotated with a renovate comment",
      "managerFilePatterns": ["/values\\.yaml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>.+?)(?:\\s+versioning=(?<versioning>[a-z-]+?))?\\s*\\n\\s*tag:\\s*[\"']?(?<currentValue>[^\"'\\s]+)[\"']?"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Update combined `image: repo:tag` strings in values.yaml (sidecars under extraContainers/initContainers are passed to the chart verbatim, so they cannot use the structured image.repository/image.tag form the manager above relies on)",
      "managerFilePatterns": ["/values\\.yaml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>.+?)(?:\\s+versioning=(?<versioning>[a-z-]+?))?\\s*\\n\\s*-?\\s*image:\\s*[\"']?[^\"'\\s]+:(?<currentValue>[^\"'\\s]+)[\"']?"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Update a version pinned in a shell variable inside values.yaml (e.g. an initContainer that downloads a GitHub release asset), annotated with a renovate comment. The datasource is taken FROM the comment (github-releases, etc.), so this is not docker-specific.",
      "managerFilePatterns": ["/values\\.yaml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>\\S+?)(?:\\s+versioning=(?<versioning>[a-z-]+))?\\s*\\n\\s*[A-Za-z_][A-Za-z0-9_]*=[\"']?(?<currentValue>[^\"'\\s]+)[\"']?"
      ],
      "datasourceTemplate": "{{{datasource}}}"
    }
  ]
}
